{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "node",
    "target": "esnext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": [],
    "types": [],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "App.js", "index.js"],
  "exclude": ["node_modules", "android", "ios", "build"]
}
