{
  "expo": {
    "name": "SafeHer",
    "slug": "girl-safety-app",
    "version": "6.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0A1628",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.girlsafety.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Girl Safety App needs your location to share with emergency contacts during emergencies.",
        "NSLocationAlwaysUsageDescription": "Girl Safety App needs your location for live tracking during emergencies."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "package": "com.girlsafety.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "SEND_SMS",
        "CALL_PHONE",
        "VIBRATE",
        "RECORD_AUDIO",
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Girl Safety App needs your location to share with emergency contacts during emergencies.",
          "locationAlwaysAndWhenInUsePermission": "Girl Safety App needs background location for live tracking during emergencies."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Girl Safety App needs microphone access to record audio evidence during emergencies."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Girl Safety App needs camera access for evidence capture."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Girl Safety App uses Face ID to securely unlock your safety features."
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "minSdkVersion": 24
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "51dab201-d25e-4da4-ba39-e89464cfda5c"
      }
    },
    "owner": "pramod068"
  }
}
